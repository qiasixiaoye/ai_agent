FROM maven:3.9.10-eclipse-temurin-21 AS build
WORKDIR /app
COPY vs-image-search-mcp-server/pom.xml pom.xml
COPY vs-image-search-mcp-server/.mvn .mvn
COPY vs-image-search-mcp-server/mvnw mvnw
COPY vs-image-search-mcp-server/src src
RUN chmod +x mvnw && ./mvnw -DskipTests clean package

FROM eclipse-temurin:21-jre
WORKDIR /app
COPY --from=build /app/target/*.jar app.jar
EXPOSE 8080
ENTRYPOINT ["java","-jar","/app/app.jar","--spring.profiles.active=sse"]
